# === Azure OpenAI ===
# Create the resource + deployment at https://oai.azure.com/portal
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_API_KEY=...
AZURE_OPENAI_DEPLOYMENT=gpt-4.1
# Latest stable API version at time of writing; bump if your resource needs it.
AZURE_OPENAI_API_VERSION=2024-10-21

# === Bing Web Search ===
# Provision at https://portal.azure.com -> "Bing Search v7". S1 tier recommended.
BING_SEARCH_API_KEY=...
# Default endpoint — override only if you're on a regional / sovereign cloud.
BING_SEARCH_ENDPOINT=https://api.bing.microsoft.com/v7.0/search

# === Optional ===
# Override the default number of web searches per agent turn.
# BING_SEARCH_RESULTS_PER_QUERY=5
